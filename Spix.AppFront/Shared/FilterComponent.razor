<div class="row g-2 align-items-center">

    <!-- Campo de búsqueda -->
    <div class="col-12 col-md">
        <div class="input-group">
            <span class="input-group-text bg-light">
                <i class="fa fa-search text-dark"></i>
            </span>
            <InputText class="form-control" placeholder="Search..." @bind-Value="FilterValue" />
        </div>
    </div>

    <!-- Botón Buscar -->
    <div class="col-auto">
        <button class="btn btn-gradient-primary d-flex align-items-center gap-2" @onclick="OnfilterApply">
            <i class="fa fa-search"></i> @Localizer["Search"]
        </button>
    </div>

    <!-- Botón Limpiar -->
    <div class="col-auto">
        <button class="btn btn-gradient-black d-flex align-items-center gap-2" @onclick="ClearFilter">
            <i class="fa fa-refresh"></i> @Localizer["Clear"]
        </button>
    </div>

</div>