@inherits ComponentBase

<div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); z-index: 1055;">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content modal-create-shadow p-4 position-relative">
            <div class="modal-header d-flex justify-content-between align-items-center mb-3">
                <h5 class="modal-title">
                    @Title
                </h5>
                <button class="btn-close-modal" @onclick="Return" title="Close">
                    <i class="fa fa-times"></i>
                </button>
            </div>

            @if (isLoading || Technician is null)
            {
                <div class="loading-overlay">
                    <Loading />
                </div>
            }
            else
            {
                @if (Technician.Active)
                {
                    <div class="d-flex justify-content-end mb-3">
                        <ButtonFormSaveOnClick OnClick="ResendActivationEmailAsync"
                                               IsSaving="IsSendingEmail"
                                               TooTip="Re-Email"
                                               Icon="fa fa-envelope"
                                               Style="width:140px" />
                    </div>
                }

                <FormTechnitian Technician="Technician"
                                IsSaving="IsSaving"
                                IsEditControl="true"
                                OnSubmit="Edit"
                                ReturnAction="Return" />
            }
        </div>
    </div>
</div>
