@page "/productcategories"
@layout MainLayout
@attribute [Authorize(Roles = "Administrator, Auxiliar")]

<div class="container-fluid pt-4">
    <div class="card shadow-lg p-4 mb-5" style="border-radius: 12px;">
        <h3 class="mb-4">@Localizer[nameof(Resource.ProductCategory)]</h3>

        <div class="row align-items-center mb-3">
            <div class="col-md-3 d-flex justify-content-start">
                <button class="btn btn-gradient-primary d-flex align-items-center gap-2" style="width:130px" @onclick="() => ShowModalAsync()">
                    <i class="fa fa-plus-circle"></i> @Localizer[nameof(Resource.New)]
                </button>
            </div>
            <div class="col-md-9 d-flex justify-content-end">
                <FilterComponent ApplyFilter="SetFilterValue" />
            </div>
        </div>

        <hr />
        <GenericList MyList="ProductCategories">
            <Body>
                <div class="table-responsive">
                    <table class="table table-hover table-striped align-middle product-category-table">
                        <thead class="table-dark">
                            <tr>
                                <th style="width: 40px;"></th>
                                <th>@Localizer[nameof(Resource.ProductCategory)]</th>
                                <th>@Localizer[nameof(Resource.Product)]</th>
                                <th>@Localizer[nameof(Resource.Active)]</th>
                                <th></th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in ProductCategories!)
                            {
                                <tr class="product-category-row @(ExpandedProductCategoryId == item.ProductCategoryId ? "is-expanded" : null)">
                                    <td style="cursor: pointer;" @onclick="() => ToggleExpandedProductCategory(item.ProductCategoryId)">
                                        <button class="btn btn-sm btn-light expand-button" type="button">
                                            <i class="fa @(ExpandedProductCategoryId == item.ProductCategoryId ? "fa-chevron-down" : "fa-chevron-right")"></i>
                                        </button>
                                    </td>
                                    <td class="category-name">@item.Name</td>
                                    <td>@item.ProductsNumer</td>
                                    <td>
                                        <input type="checkbox" class="form-check-input" checked="@item.Active" disabled />
                                    </td>
                                    <td style="width:1px;">
                                        <ButtonEdit OnClick="() => ShowModalAsync(item.ProductCategoryId, true)" />
                                    </td>
                                    <td style="width:1px;">
                                        <ButtonDelete OnClick="() => DeleteAsync(item.ProductCategoryId)" />
                                    </td>
                                </tr>

                                @if (ExpandedProductCategoryId == item.ProductCategoryId)
                                {
                                    <tr class="products-expanded-row">
                                        <td colspan="6">
                                            <section class="products-panel">
                                                <button class="btn btn-sm btn-gradient-primary products-new-button" @onclick="() => ShowModalProductAsync(item.ProductCategoryId)">
                                                    <i class="fa fa-plus"></i> @Localizer[nameof(Resource.New)] @Localizer[nameof(Resource.Product)]
                                                </button>

                                                @if (LoadingProductCategoryIds.Contains(item.ProductCategoryId))
                                                {
                                                    <div class="products-empty-state">
                                                        <div class="spinner-border text-primary" role="status">
                                                            <span class="visually-hidden">Loading...</span>
                                                        </div>
                                                        <p>@Localizer["Loading"] @Localizer[nameof(Resource.Product)]...</p>
                                                    </div>
                                                }

                                                @if (!LoadingProductCategoryIds.Contains(item.ProductCategoryId) && ProductsByCategoryId.ContainsKey(item.ProductCategoryId))
                                                {
                                                    @if (ProductsByCategoryId[item.ProductCategoryId].Any())
                                                    {
                                                        <div class="products-list" role="list">
                                                            <div class="products-list-header">
                                                                <span>@Localizer[nameof(Resource.Product)]</span>
                                                                <span>@Localizer[nameof(Resource.Stock)]</span>
                                                                <span>@Localizer[nameof(Resource.WithSerials)]</span>
                                                                <span>@Localizer[nameof(Resource.Active)]</span>
                                                                <span>@Localizer[nameof(Resource.Action)]</span>
                                                            </div>

                                                            @foreach (var product in ProductsByCategoryId[item.ProductCategoryId])
                                                            {
                                                                <div class="products-list-row" role="listitem">
                                                                    <div class="product-name">@product.ProductName</div>
                                                                    <div class="product-stock">@product.TotalInventario</div>
                                                                    <div class="product-serials">
                                                                        <input type="checkbox" class="form-check-input" checked="@product.WithSerials" disabled />
                                                                    </div>
                                                                    <div class="product-active">
                                                                        <input type="checkbox" class="form-check-input" checked="@product.Active" disabled />
                                                                    </div>
                                                                    <div class="product-actions">
                                                                        <ButtonGeneric OnClick="() => ShowModalStockAsync(product.ProductId)" TooTip="@Localizer[nameof(Resource.Stock)]" Icon="fa fa-warehouse" />
                                                                        <ButtonEdit OnClick="() => ShowModalProductAsync(product.ProductCategoryId, product.ProductId, true)" />
                                                                        <ButtonDelete OnClick="() => DeleteProductAsync(product.ProductCategoryId, product.ProductId)" />
                                                                    </div>
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div class="products-empty-state" role="alert">
                                                            <i class="fa fa-info-circle"></i> @Localizer["NoRecordsFound"]
                                                        </div>
                                                    }
                                                }
                                            </section>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </Body>
        </GenericList>

        <hr />
        <Pagination CurrentPage="CurrentPage"
                    SelectedPage="SelectedPage"
                    TotalPages="TotalPages" />
    </div>
</div>
