@inherits ComponentBase

<div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); z-index: 1055;">
    <div class="modal-dialog modal-md modal-dialog-centered">
        <div class="modal-content modal-create-shadow p-4 position-relative">
            <div class="modal-header d-flex justify-content-between align-items-center mb-3">
                <h5 class="modal-title">@Title</h5>
                <button class="btn-close-modal" @onclick="Return" title="Close">
                    <i class="fa fa-times"></i>
                </button>
            </div>

            <EditForm Model="Model" OnValidSubmit="CancelAsync">
                <DataAnnotationsValidator />

                <div class="input-group">
                    <span class="input-group-text" style="width:110px">Motivo</span>
                    <textarea class="form-control" rows="5" @bind="Model.DescriptionCancelled"></textarea>
                </div>
                <ValidationMessage For="@(() => Model.DescriptionCancelled)" />

                <hr />
                <div class="d-flex justify-content-center gap-3 mt-4">
                    <ButtonFormSave IsSaving="IsSaving" />
                    <ButtonFormBack OnClick="Return" />
                </div>
            </EditForm>
        </div>
    </div>
</div>
