@page "/ipnets"
@attribute [Authorize(Roles = "Administrator")]


<div class="container pt-4">
    <div class="card shadow-lg p-4 mb-5" style="border-radius: 12px;">
        <h3>IP Address Clientes</h3>

        <!-- Botón + Filtro -->
        <div class="row align-items-center mb-3">
            <div class="col-md-3 d-flex justify-content-start">
                <button class="btn btn-gradient-primary d-flex align-items-center gap-2" style="width:130px" @onclick="() => ShowModalAsync()">
                    <i class="fa fa-plus-circle"></i> Zona
                </button>
            </div>
            <div class="col-md-9 d-flex justify-content-end">
                <FilterComponent ApplyFilter="SetFilterValue" />
            </div>
        </div>
        <hr />
        <GenericList MyList="IpNets">
            <Body>
                <div class="table-responsive">
                    <table class="table table-hover table-striped align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>Ip</th>
                                <th>Descripcion</th>
                                <th>Activa</th>
                                <th>Asignada</th>
                                <th>Excluida</th>
                                <th></th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in IpNets!)
                            {
                                <tr>
                                    <td>
                                        @item.Ip
                                    </td>
                                    <td>
                                        @item.Description
                                    </td>
                                    <td>
                                        <input type="checkbox" class="form-check-input" checked="@item.Active" disabled />
                                    </td>
                                    <td>
                                        <input type="checkbox" class="form-check-input" checked="@item.Assigned" disabled />
                                    </td>
                                    <td>
                                        <input type="checkbox" class="form-check-input" checked="@item.Excluded" disabled />
                                    </td>
                                    <td style="width:1px;">

                                        <ButtonEdit OnClick="() => ShowModalAsync(item.IpNetId, true)" />
                                        
                                    </td>
                                    <td style="width:1px;">
                          
                                        <ButtonDelete OnClick="() => DeleteAsync(item.IpNetId)" />
                                        
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </Body>
        </GenericList>
        <hr />
        <Pagination CurrentPage="CurrentPage"
                    SelectedPage="SelectedPage"
                    TotalPages="TotalPages" />
    </div>
</div>

