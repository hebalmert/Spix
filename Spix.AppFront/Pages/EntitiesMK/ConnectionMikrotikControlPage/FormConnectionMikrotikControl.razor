<EditForm Model="ConnectionMikrotikControl" OnValidSubmit="OnSubmit">
    <DataAnnotationsValidator />

    <div class="row">
        <div class="col-md-12 mb-2">
            <div class="input-group">
                <span class="input-group-text" style="width: 150px">
                    Tipo Control
                </span>
                <InputSelect class="form-select" @bind-Value="ConnectionMikrotikControl.MikrotikControlType">
                    @foreach (var item in ControlTypes)
                    {
                        <option value="@item">@item</option>
                    }
                </InputSelect>
            </div>
            <ValidationMessage For="@(() => ConnectionMikrotikControl.MikrotikControlType)" />
        </div>
    </div>

    <div class="d-flex justify-content-center gap-3 mt-5">
        <ButtonFormSave IsSaving="IsSaving" />
        <ButtonFormBack OnClick="ReturnAction" />
    </div>
</EditForm>
