@page "/queuetypes"
@layout MainLayout
@attribute [Authorize(Roles = "Administrator, Auxiliar")]

<div class="container pt-4">
    <div class="card shadow-lg p-4 mb-5" style="border-radius: 12px;">
        <h3 class="mb-4">Queue Types</h3>

        <div class="row align-items-center mb-3">
            <div class="col-md-3 d-flex justify-content-start">
                <button class="btn btn-gradient-primary d-flex align-items-center gap-2" style="width:150px" @onclick="() => ShowModalAsync()">
                    <i class="fa fa-plus-circle"></i> Nuevo
                </button>
            </div>
        </div>

        <hr />
        <GenericList MyList="QueueTypes">
            <Body>
                <div class="table-responsive">
                    <table class="table table-hover table-striped align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>Queue Type</th>
                                <th class="text-center">Down</th>
                                <th class="text-center">Up</th>
                                <th class="text-center">Activo</th>
                                <th></th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in QueueTypes!)
                            {
                                <tr>
                                    <td>@item.TypeName</td>
                                    <td class="text-center">
                                        <InputCheckbox class="form-check-input" Value="item.Down" ValueChanged="(_) => Task.CompletedTask" ValueExpression="@(() => item.Down)" disabled />
                                    </td>
                                    <td class="text-center">
                                        <InputCheckbox class="form-check-input" Value="item.Up" ValueChanged="(_) => Task.CompletedTask" ValueExpression="@(() => item.Up)" disabled />
                                    </td>
                                    <td class="text-center">
                                        <InputCheckbox class="form-check-input" Value="item.Active" ValueChanged="(_) => Task.CompletedTask" ValueExpression="@(() => item.Active)" disabled />
                                    </td>
                                    <td style="width:1px;">
                                        <ButtonEdit OnClick="() => ShowModalAsync(item.QueueTypeId, true)" />
                                    </td>
                                    <td style="width:1px;">
                                        <ButtonDelete OnClick="() => DeleteAsync(item.QueueTypeId)" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </Body>
        </GenericList>

        <hr />
        <Pagination CurrentPage="CurrentPage"
                    SelectedPage="SelectedPage"
                    TotalPages="TotalPages" />
    </div>
</div>
