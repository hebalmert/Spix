<EditForm Model="QueueType" OnValidSubmit="OnSubmit">
    <DataAnnotationsValidator />

    <div class="row">
        <div class="col-md-12 mb-2">
            <div class="input-group">
                <span class="input-group-text" style="width: 150px">
                    Queue Type
                </span>
                <InputText class="form-control" @bind-Value="QueueType.TypeName" />
            </div>
            <ValidationMessage For="@(() => QueueType.TypeName)" />
        </div>
    </div>

    <div class="row">
        <div class="col-md-12 mb-2">
            <div class="input-group">
                <span class="input-group-text" style="width: 150px">
                    Down
                </span>
                <div class="d-flex align-items-center ps-3">
                    <InputCheckbox @bind-Value="QueueType.Down" class="form-check-input me-2" />
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12 mb-2">
            <div class="input-group">
                <span class="input-group-text" style="width: 150px">
                    Up
                </span>
                <div class="d-flex align-items-center ps-3">
                    <InputCheckbox @bind-Value="QueueType.Up" class="form-check-input me-2" />
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12 mb-2">
            <div class="input-group">
                <span class="input-group-text" style="width: 150px">
                    Activo
                </span>
                <div class="d-flex align-items-center ps-3">
                    <InputCheckbox @bind-Value="QueueType.Active" class="form-check-input me-2" />
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-center gap-3 mt-5">
        <ButtonFormSave IsSaving="IsSaving" />
        <ButtonFormBack OnClick="ReturnAction" />
    </div>
</EditForm>
