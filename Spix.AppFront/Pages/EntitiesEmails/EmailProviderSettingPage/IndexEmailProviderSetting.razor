@page "/emailproviders"
@layout MainLayout
@attribute [Authorize(Roles = "Administrator")]

<div class="container pt-4">
    <div class="card shadow-lg p-4 mb-5" style="border-radius: 12px;">
        <h3 class="mb-4">Setup Emails</h3>

        <div class="row align-items-center mb-3">
            <div class="col-md-3 d-flex justify-content-start">
                <ButtonFormNew OnClick="() => ShowModalAsync()" TooTip="Nueva" />
            </div>
            <div class="col-md-9 d-flex justify-content-end">
                <FilterComponent ApplyFilter="SetFilterValue" />
            </div>
        </div>

        <hr />
        <GenericList MyList="EmailProviders">
            <Body>
                <div class="table-responsive">
                    <table class="table table-hover table-striped align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>Nombre</th>
                                <th>Proveedor</th>
                                <th>Correo</th>
                                <th>Default</th>
                                <th>Activo</th>
                                <th></th>
                                <th></th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in EmailProviders!)
                            {
                                <tr>
                                    <td>@item.Name</td>
                                    <td>@item.ProviderType</td>
                                    <td>@item.FromEmail</td>
                                    <td>
                                        <input type="checkbox" class="form-check-input" checked="@item.IsDefault" disabled />
                                    </td>
                                    <td>
                                        <input type="checkbox" class="form-check-input" checked="@item.Active" disabled />
                                    </td>
                                    <td style="width:1px;">
                                        <ButtonGeneric Icon="fa fa-paper-plane" TooTip="Email-test" CssClass="btn-mini-success" OnClick="() => TestEmailAsync(item.EmailProviderSettingId)" />
                                    </td>
                                    <td style="width:1px;">
                                        <ButtonEdit OnClick="() => ShowModalAsync(item.EmailProviderSettingId, true)" />
                                    </td>
                                    <td style="width:1px;">
                                        <ButtonDelete OnClick="() => DeleteAsync(item.EmailProviderSettingId)" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </Body>
        </GenericList>

        <hr />
        <Pagination CurrentPage="CurrentPage"
                    SelectedPage="SelectedPage"
                    TotalPages="TotalPages" />
    </div>
</div>
