@inherits ComponentBase

<div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); z-index: 1055;">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content modal-create-shadow p-4 position-relative">
            <div class="modal-header d-flex justify-content-between align-items-center mb-3">
                <h5 class="modal-title">@Title</h5>
                <button class="btn-close-modal" @onclick="Return" title="Close">
                    <i class="fa fa-times"></i>
                </button>
            </div>

            @if (isLoading || Model is null)
            {
                <Loading />
            }
            else
            {
                @if (!string.IsNullOrWhiteSpace(Model.FileFullPath))
                {
                    <iframe src="@Model.FileFullPath" style="border:1px solid #ddd; width:100%; height:620px; border-radius:8px;"></iframe>
                }

                @if (!Model.Signed)
                {
                    <hr />
                    <div class="d-flex justify-content-center">
                        <canvas id="@CanvasId" width="420" height="130" style="width:420px; height:130px; border:1px solid #222; border-radius:6px;"></canvas>
                    </div>
                    <div class="d-flex justify-content-center gap-3 mt-3">
                        <ButtonGeneric OnClick="ClearSignature"
                                       Icon="fa fa-rotate-right"
                                       TooTip="Clear"
                                       CssClass="btn-mini"
                                       Style="font-size:17px;color:#198754;" />
                    </div>
                }

                <hr />
                <div class="d-flex justify-content-center gap-3">
                    @if (!Model.Signed)
                    {
                        <ButtonFormSaveOnClick OnClick="SaveSignature" IsSaving="IsSaving" />
                    }
                    <ButtonFormBack OnClick="Return" />
                </div>
            }
        </div>
    </div>
</div>
