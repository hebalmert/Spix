@using Spix.AppFront.Shared
@using Spix.Domain.EntitiesContratos
@using Spix.DomainLogic.EnumTypes

<EditForm Model="Template" OnValidSubmit="OnSubmit">
    <DataAnnotationsValidator />

    <div class="row g-2">
        <div class="col-12">
            <div class="input-group">
                <span class="input-group-text" style="width:130px">Nombre</span>
                <input class="form-control" @bind="Template.Name" />
            </div>
            <ValidationMessage For="@(() => Template.Name)" />
        </div>
    </div>

    <div class="row g-2 mt-2">
        <div class="col-12 col-md-6">
            <div class="input-group">
                <span class="input-group-text" style="width:110px">Tipo</span>
                <select class="form-select" value="@((int)Template.DocumentType)" @onchange="DocumentTypeChanged">
                    <option value="1">Consent Datos</option>
                    <option value="2">Contrato</option>
                </select>
            </div>
        </div>

        <div class="col-12 col-md-6">
            <div class="input-group">
                <span class="input-group-text" style="width:110px">Paginas</span>
                <input class="form-control" type="number" min="1" @bind="Template.PageCount" />
            </div>
            <ValidationMessage For="@(() => Template.PageCount)" />
        </div>
    </div>

    <div class="row g-2 mt-2">
        <div class="col-12 col-md-4">
            <div class="input-group">
                <span class="input-group-text" style="width:130px">Activo</span>
                <div class="form-control">
                    <input class="form-check-input" type="checkbox" @bind="Template.Active" />
                </div>
            </div>
        </div>

        <div class="col-12 col-md-8">
            <InputDocument Label="PDF"
                           AcceptExtensions=".pdf"
                           PreviewUrl="@Template.FileFullPath"
                           DocumentSelected="DocumentSelected" />
        </div>
    </div>

    <hr />

    @if (ShowFields)
    {
        <h5>Coordenadas</h5>

        <div class="row g-2 align-items-end mb-3">
            <div class="col-12 col-md-4">
                <label class="form-label mb-1">Campo</label>
                <select class="form-select" value="@((int)NewField.FieldType)" @onchange="FieldTypeChanged">
                    <option value="1">Nombre</option>
                    <option value="2">Documento</option>
                    <option value="3">Telefono</option>
                    <option value="4">Fecha</option>
                    <option value="5">Firma</option>
                </select>
            </div>
            <div class="col-12 col-md-7">
                <div class="row g-2">
                    <div class="col-4">
                        <label class="form-label mb-1">Pagina</label>
                        <input class="form-control" type="number" min="1" placeholder="Pag" @bind="NewField.PageNumber" />
                    </div>
                    <div class="col-4">
                        <label class="form-label mb-1">X</label>
                        <input class="form-control" type="number" step="0.01" placeholder="X" @bind="NewField.PositionX" />
                    </div>
                    <div class="col-4">
                        <label class="form-label mb-1">Y</label>
                        <input class="form-control" type="number" step="0.01" placeholder="Y" @bind="NewField.PositionY" />
                    </div>
                    <div class="col-4">
                        <label class="form-label mb-1">Ancho</label>
                        <input class="form-control" type="number" step="0.01" placeholder="W" @bind="NewField.Width" />
                    </div>
                    <div class="col-4">
                        <label class="form-label mb-1">Alto</label>
                        <input class="form-control" type="number" step="0.01" placeholder="H" @bind="NewField.Height" />
                    </div>
                    <div class="col-4">
                        <label class="form-label mb-1">Font</label>
                        <input class="form-control" type="number" min="1" placeholder="Font" @bind="NewField.FontSize" />
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-1 pb-1">
                <ButtonGeneric OnClick="AddField"
                               Icon="fa fa-plus-circle"
                               TooTip="Agregar"
                               CssClass="btn-mini"
                               Style="font-size:17px;color:#198754;" />
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover table-striped align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Campo</th>
                        <th>Pagina</th>
                        <th>X</th>
                        <th>Y</th>
                        <th>W</th>
                        <th>H</th>
                        <th>Font</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var field in Fields)
                    {
                        <tr>
                            <td>@GetFieldName(field.FieldType)</td>
                            <td>@field.PageNumber</td>
                            <td>@field.PositionX</td>
                            <td>@field.PositionY</td>
                            <td>@field.Width</td>
                            <td>@field.Height</td>
                            <td>@field.FontSize</td>
                            <td style="width:1px;">
                                <ButtonDelete OnClick="() => DeleteField(field)" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <hr />
    }

    <div class="d-flex justify-content-center gap-3 mt-4">
        <ButtonFormSave IsSaving="IsSaving" />
        <ButtonFormBack OnClick="ReturnAction" />
    </div>
</EditForm>
