<EditForm Model="ContractQue" OnValidSubmit="OnSubmit">
    <DataAnnotationsValidator />

    <div class="input-group mb-2">
        <span class="input-group-text" style="width:150px">Servidor</span>
        <InputText class="form-control" @bind-Value="ContractQue.ServerName" readonly />
    </div>

    <div class="input-group mb-2">
        <span class="input-group-text" style="width:150px">IP Cliente</span>
        <InputText class="form-control" @bind-Value="ContractQue.IpCliente" readonly />
    </div>

    <div class="input-group mb-2">
        <span class="input-group-text" style="width:150px">Plan</span>
        <InputText class="form-control" @bind-Value="ContractQue.PlanName" readonly />
    </div>

    <div class="input-group mb-2">
        <span class="input-group-text" style="width:150px">Velocidad</span>
        <InputText class="form-control" @bind-Value="ContractQue.TotalVelocidad" readonly />
    </div>

    <div class="d-flex justify-content-center gap-3 mt-5">
        <ButtonFormSave IsSaving="IsSaving" />
        <ButtonFormBack OnClick="ReturnAction" />
    </div>
</EditForm>
