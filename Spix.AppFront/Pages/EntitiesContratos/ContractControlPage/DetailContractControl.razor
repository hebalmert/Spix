@page "/detailscontractcontrol/{Id:guid}"
@layout MainLayout
@attribute [Authorize(Roles = "Administrator")]

<div class="container-fluid contract-detail-page py-4">
    <div class="contract-shell">
        @if (ContractClient is null)
        {
            <Loading />
        }
        else
        {
            <section class="contract-summary">
                <div class="d-flex align-items-center justify-content-between gap-3 flex-wrap">
                    <h2 class="contract-title">Detalle Contrato</h2>

                    <div class="contract-actions">
                        <AnchorFormBack Href="/contractcontrol"
                                        CssClass="btn btn-outline-dark contract-action"
                                        Style="" />
                        <ButtonFormNew Icon="fa fa-pencil-square"
                                       CssClass="btn btn-outline-primary contract-action"
                                       Style=""
                                       OnClick="() => ShowEditContractClient(ContractClient!.ContractClientId)"
                                       TooTip="@Localizer[nameof(Resource.Edit)]" />
                        <button type="button" title="Retirar" class="btn contract-action contract-action-danger">
                            <i class="fa fa-cloud-arrow-down"></i>
                            <span>Retirar</span>
                        </button>
                    </div>
                </div>

                <hr class="summary-divider" />

                <div class="info-grid">
                    <div class="info-item">
                        <span class="info-label">@Localizer[nameof(Resource.Created)]</span>
                        <span class="info-value">@ContractClient.DateCreado</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">@Localizer[nameof(Resource.Contract)]</span>
                        <span class="info-value info-value-strong">@ContractClient.ControlContrato</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">@Localizer[nameof(Resource.Contractor)]</span>
                        <span class="info-value">@ContractClient.Contractor!.FirstName @ContractClient.Contractor.LastName</span>
                    </div>
                </div>

                <div class="info-grid info-grid-wide client-info-grid summary-section">
                    <div class="info-item">
                        <span class="info-label">@Localizer[nameof(Resource.Client)]</span>
                        <span class="info-value">@ContractClient.Client!.FirstName @ContractClient.Client.LastName</span>
                    </div>
                    <div class="info-item info-item-document">
                        <span class="info-label">@Localizer[nameof(Resource.Document)]</span>
                        <span class="info-value">@ContractClient.Client.DocumentType!.DocumentName</span>
                        <span class="info-value">@ContractClient.Client.Document</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">@Localizer[nameof(Resource.Phone)]</span>
                        <span class="info-value">@ContractClient.PhoneNumber</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">@Localizer[nameof(Resource.Email)]</span>
                        <span class="info-value">@ContractClient.Client.Email</span>
                    </div>
                    <div class="info-item info-item-wide">
                        <span class="info-label">@Localizer[nameof(Resource.Address)]</span>
                        <span class="info-value">@ContractClient.Address</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">@Localizer[nameof(Resource.City)]</span>
                        <span class="info-value">@ContractClient.Zone!.City!.Name</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">@Localizer[nameof(Resource.Zone)]</span>
                        <span class="info-value">@ContractClient.Zone.ZoneName</span>
                    </div>
                </div>

                <div class="status-row summary-section">
                    <div class="status-tile">
                        <input class="form-check-input" type="checkbox" checked="@ContractClient.EquipoEmpres" disabled />
                        <span>Equipo</span>
                    </div>
                    <div class="status-tile">
                        <input class="form-check-input" type="checkbox" checked="@ContractClient.EnvoiceClient" disabled />
                        <span>Invoice</span>
                    </div>
                    <div class="status-tile">
                        <span class="status-pill">@ContractClient.ContractState</span>
                    </div>
                </div>
            </section>

            <section class="row g-4 mt-1 control-grid">
                <div class="col-xl-4 col-md-6">
                    <article class="control-card">
                        <header class="control-card-header">
                            <span class="control-icon"><i class="fa fa-ethernet"></i></span>
                            <span>IP Cliente</span>
                        </header>
                        <div class="control-body">
                            @if (ContractIp is null || ContractIp.ContractIpId == Guid.Empty)
                            {
                                <p class="control-empty">Sin IP Asignada...</p>
                                <div class="control-action">
                                    <ButtonGeneric OnClick="() => ShowContractIpsAsyn(ContractClient!.ContractClientId)"
                                                   TooTip="@Localizer[nameof(Resource.Create_IDPics)]"
                                                   Icon="fa fa-plus" />
                                </div>
                            }
                            else
                            {
                                <div class="control-data control-data-one">
                                    <span class="control-value">@ContractIp.IpNet!.Ip</span>
                                </div>
                                <div class="control-action">
                                    <ButtonDelete OnClick="() => DeleteContractIpAsync(ContractIp!.ContractIpId)"
                                                  TooTip="@Localizer[nameof(Resource.Create_IDPics)]"
                                                  Icon="fa fa-trash" />
                                </div>
                            }
                        </div>
                    </article>
                </div>

                <div class="col-xl-4 col-md-6">
                    <article class="control-card">
                        <header class="control-card-header">
                            <span class="control-icon"><i class="fa fa-gears"></i></span>
                            <span>Mac Equipo</span>
                        </header>
                        <div class="control-body">
                            @if (ContractMac is null || ContractMac.ContractMacId == Guid.Empty)
                            {
                                <p class="control-empty">Sin MAC Asignada...</p>
                                <div class="control-action">
                                    <ButtonGeneric OnClick="() => ShowContractMacsAsyn(ContractClient!.ContractClientId)"
                                                   TooTip="@Localizer[nameof(Resource.Create_Mac)]"
                                                   Icon="fa fa-plus" />
                                </div>
                            }
                            else
                            {
                                <div class="control-data control-data-one">
                                    <span class="control-value">@ContractMac.CargueDetail!.MacWlan</span>
                                </div>
                                <div class="control-action">
                                    <ButtonDelete OnClick="() => DeleteContractMacAsync(ContractMac!.ContractMacId)"
                                                  TooTip="@Localizer[nameof(Resource.Create_Mac)]"
                                                  Icon="fa fa-trash" />
                                </div>
                            }
                        </div>
                    </article>
                </div>

                <div class="col-xl-4 col-md-6">
                    <article class="control-card">
                        <header class="control-card-header">
                            <span class="control-icon"><i class="fa fa-server"></i></span>
                            <span>Servidor Gateway</span>
                        </header>
                        <div class="control-body">
                            @if (ContractServer is null || ContractServer.ContractServerId == Guid.Empty)
                            {
                                <p class="control-empty">Sin Servidor Asignado...</p>
                                <div class="control-action">
                                    <ButtonGeneric OnClick="() => ShowContractServersAsyn(ContractClient!.ContractClientId)"
                                                   TooTip="@Localizer[nameof(Resource.Create_Server)]"
                                                   Icon="fa fa-plus" />
                                </div>
                            }
                            else
                            {
                                <div class="control-data control-data-one">
                                    <span class="control-value">@ContractServer.Server!.ServerName</span>
                                </div>
                                <div class="control-action">
                                    <ButtonDelete OnClick="() => DeleteContractServerAsync(ContractServer!.ContractServerId)"
                                                  TooTip="@Localizer[nameof(Resource.Create_Server)]"
                                                  Icon="fa fa-trash" />
                                </div>
                            }
                        </div>
                    </article>
                </div>

                <div class="col-xl-6">
                    <article class="control-card">
                        <header class="control-card-header">
                            <span class="control-icon"><i class="fa fa-gauge-high"></i></span>
                            <span>Plan Cliente</span>
                        </header>
                        <div class="control-body">
                            @if (ContractPlan is null || ContractPlan.ContractPlanId == Guid.Empty)
                            {
                                <p class="control-empty">Sin Plan Asignado...</p>
                                <div class="control-action">
                                    <ButtonGeneric OnClick="() => ShowContractPlansAsyn(ContractClient!.ContractClientId)"
                                                   TooTip="@Localizer[nameof(Resource.ClientPlan)]"
                                                   Icon="fa fa-plus" />
                                </div>
                            }
                            else
                            {
                                <div class="control-data">
                                    <span class="control-value">@ContractPlan.Plan!.PlanName</span>
                                    <span class="control-value control-value-center">@ContractPlan.Plan!.VelocidadTotal</span>
                                    <span class="control-value control-value-end">@ContractPlan.Plan!.PrecioconImpuesto?.ToString("N2")</span>
                                </div>
                                <div class="control-action">
                                    <ButtonDelete OnClick="() => DeleteContractPlanAsync(ContractPlan!.ContractPlanId)"
                                                  TooTip="@Localizer[nameof(Resource.ClientPlan)]"
                                                  Icon="fa fa-trash" />
                                </div>
                            }
                        </div>
                    </article>
                </div>

                <div class="col-xl-6">
                    <article class="control-card">
                        <header class="control-card-header">
                            <span class="control-icon"><i class="fa fa-tower-broadcast"></i></span>
                            <span>Nodo Acceso</span>
                        </header>
                        <div class="control-body">
                            @if (ContractNode is null || ContractNode.ContractNodeId == Guid.Empty)
                            {
                                <p class="control-empty">Sin Nodo Asignado...</p>
                                <div class="control-action">
                                    <ButtonGeneric OnClick="() => ShowContractNodesAsyn(ContractClient!.ContractClientId)"
                                                   TooTip="@Localizer[nameof(Resource.ClientAP)]"
                                                   Icon="fa fa-plus" />
                                </div>
                            }
                            else
                            {
                                <div class="control-data control-data-two">
                                    <span class="control-value">@ContractNode.Node!.NodesName</span>
                                    <span class="control-value control-value-center">@ContractNode.Node!.IpNetwork?.Ip</span>
                                </div>
                                <div class="control-action">
                                    <ButtonDelete OnClick="() => DeleteContractNodeAsync(ContractNode!.ContractNodeId)"
                                                  TooTip="@Localizer[nameof(Resource.ClientAP)]"
                                                  Icon="fa fa-trash" />
                                </div>
                            }
                        </div>
                    </article>
                </div>
            </section>
        }
    </div>
</div>
