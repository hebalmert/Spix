<EditForm Model="ContractBind" OnSubmit="OnSubmit">
    <DataAnnotationsValidator />
    @if (HotSpotTypes is null)
    {
        <Loading />
    }
    else
    {
        <div class="input-group mb-2">
            <span class="input-group-text" style="width:150px">Servidor</span>
            <InputText class="form-control" @bind-Value="ContractBind.ServerName" readonly />
        </div>

        <div class="input-group mb-2">
            <span class="input-group-text" style="width:150px">IP Cliente</span>
            <InputText class="form-control" @bind-Value="ContractBind.IpCliente" readonly />
        </div>

        <div class="input-group mb-2">
            <span class="input-group-text" style="width:150px">MAC Cliente</span>
            <InputText class="form-control" @bind-Value="ContractBind.MacCliente" readonly />
        </div>

        <div class="input-group">
            <span class="input-group-text" style="width:150px">Tipo Acceso</span>
            <select class="form-select" value="@ContractBind.HotSpotTypeId" @onchange="HotSpotTypeChanged">
                @foreach (var item in HotSpotTypes)
                {
                    <option value="@item.Value">@item.Name</option>
                }
            </select>
        </div>
    }

    <div class="d-flex justify-content-center gap-3 mt-5">
        <ButtonFormSave IsSaving="IsSaving" />
        <ButtonFormBack OnClick="ReturnAction" />
    </div>
</EditForm>
