<EditForm Model="ContractNode" OnValidSubmit="OnSubmit">
    <DataAnnotationsValidator />
    @if (Nodes is null)
    {
        <Loading />
    }
    else
    {
        <div class="input-group">
            <span class="input-group-text" style="width:150px">@Localizer[nameof(Resource.ClientAP)]</span>
            <select class="form-select" value="@ContractNode?.NodeId" @onchange="NodeChanged">
                @foreach (var item in Nodes!)
                {
                    <option value="@item.NodeId">@item.NodesName</option>
                }
            </select>
        </div>
    }

    <div class="d-flex justify-content-center gap-3 mt-5">
        <ButtonFormSave IsSaving="IsSaving" />
        <ButtonFormBack OnClick="ReturnAction" />
    </div>
</EditForm>
