@page "/contractclients"
@attribute [Authorize(Roles = "Administrator, Auxiliar")]

<div class="container pt-4">
    <div class="card shadow-lg p-4 mb-5" style="border-radius: 12px;">
        <h3 class="mb-4">@Localizer[nameof(Resource.Control_Contracts)]</h3>

        <!-- Botón + Filtro -->
        <div class="row align-items-center mb-3">
            <div class="col-md-3 d-flex justify-content-start">
                <button class="btn btn-gradient-primary d-flex align-items-center gap-2" style="width:130px" @onclick="() => ShowModalAsync()">
                    <i class="fa fa-plus-circle"></i> @Localizer[nameof(Resource.New)]
                </button>
            </div>
            <div class="col-md-9 d-flex justify-content-end">
                <FilterComponent ApplyFilter="SetFilterValue" />
            </div>
        </div>

        <hr />
        <GenericList MyList="ContractClients">
            <Body>
                <div class="table-responsive">
                    <table class="table table-hover table-striped align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>@Localizer[nameof(Resource.Contracts)]</th>
                                <th>@Localizer[nameof(Resource.Client)]</th>
                                <th>@Localizer[nameof(Resource.Contractor)]</th>
                                <th>@Localizer[nameof(Resource.Equipment)]</th>
                                <th>@Localizer[nameof(Resource.Invoice)]</th>
                                <th>@Localizer[nameof(Resource.Status)]</th>
                                <th></th>
                                <th></th>
                                <th></th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in ContractClients!)
                            {
                                <tr>
                                    <td>@item.ControlContrato</td>
                                    <td>@item.Client!.FirstName @item.Client.LastName</td>
                                    <td>@item.Contractor!.FirstName @item.Contractor.LastName</td>
                                    <td>
                                        <input type="checkbox" class="form-check-input" checked="@item.EquipoEmpres" disabled />
                                    </td>
                                    <td>
                                        <input type="checkbox" class="form-check-input" checked="@item.EnvoiceClient" disabled />
                                    </td>
                                    <td>
                                        <StatusBadge Value="@item.ContractState" />
                                    </td>

                                  
                                    <td style="width:1px;">
                                        @if (item.TieneIDPic)
                                        {
                                            <ButtonGeneric OnClick="() => ShowModalidpicsAsync(item.ContractClientId, item.ContractIDPic!.ContractIDPicId)"
                                                           TooTip="@Localizer[nameof(Resource.Edit_IDPics)]"
                                                           Icon="fa fa-id-card" />
                                        }
                                        else
                                        {
                                            <ButtonGeneric OnClick="() => ShowModalidpicsAsync(item.ContractClientId, null)"
                                                           TooTip="@Localizer[nameof(Resource.Create_IDPics)]"
                                                           Icon="fa fa-id-card" />
                                        }
                                    </td>

                                    <td style="width:1px;">
                                        |
                                    </td>
                                    <td style="width:1px;">
                                        <ButtonEdit OnClick="() => ShowModalAsync(item.ContractClientId, true)" />
                                    </td>
                                    <td style="width:1px;">
                                        <ButtonDelete OnClick="() => DeleteAsync(item.ContractClientId)" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </Body>
        </GenericList>
        <!-- Tabla -->
        <hr />
        @if (ContractClients is not null)
        {
            <!-- Paginación -->
            <Pagination CurrentPage="CurrentPage"
                        SelectedPage="SelectedPage"
                        TotalPages="TotalPages" />
        }
    </div>
</div>