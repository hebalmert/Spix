@page "/suppliers"
@attribute [Authorize(Roles = "Administrator")]

<div class="container pt-4">
    <div class="card shadow-lg p-4 mb-5" style="border-radius: 12px;">
        <h3 class="mb-4">@Localizer[nameof(Resource.Supplier)]</h3>

        <!-- Botón + Filtro -->
        <div class="row align-items-center mb-3">
            <div class="col-md-3 d-flex justify-content-start">
                <button class="btn btn-gradient-primary d-flex align-items-center gap-2" style="width:130px" @onclick="() => ShowModalAsync()">
                    <i class="fa fa-plus-circle"></i> @Localizer[nameof(Resource.New)]
                </button>
            </div>
            <div class="col-md-9 d-flex justify-content-end">
                <FilterComponent ApplyFilter="SetFilterValue" />
            </div>
        </div>

        <hr class="border-top border-dark opacity-75 my-3" />

        <!-- Tabla -->
        <div class="table-responsive">
            <GenericList MyList="Suppliers">
                <Body>
                    <table class="table table-hover table-striped align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>@Localizer[nameof(Resource.Logo)]</th>
                                <th>@Localizer[nameof(Resource.Supplier)]</th>
                                <th>@Localizer[nameof(Resource.Phone)]</th>
                                <th>@Localizer[nameof(Resource.Email)]</th>
                                <th>@Localizer[nameof(Resource.Active)]</th>
                                <th></th>
                                <th colspan="3" class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Suppliers!)
                            {
                                <tr>
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.ImageFullPath))
                                        {
                                            <img src="@item.ImageFullPath" alt="Picture" width="90" height="90"
                                                 style="border-radius:50%" onerror="this.src='/Images/NoImage.png'" />
                                        }
                                        else
                                        {
                                            <img src="https://spiximage.blob.core.windows.net/imgwwwroot/NoImage.png" alt="NotPicture" width="90" height="90" style="border-radius:50%" />
                                        }
                                    </td>
                                    <td>@item.Name</td>
                                    <td>@($"({item.CodeCountry}) {item.CodeNumber}-{item.PhoneNumber}")</td>
                                    <td>@item.Email</td>
                                    <td>@item.Active</td>
                                    <td>
                                        <input type="checkbox" class="form-check-input" checked="@item.Active" disabled />
                                    </td>
                                    <td style="width:1px;">
                                        <ButtonGeneric Icon="fa fa-list" OnClick="() => ShowDetailsAsync(item.SupplierId)" />
                                    </td>
                                    <td style="width:1px;">
                                        <ButtonEdit OnClick="() => ShowModalAsync(item.SupplierId, true)" />
                                    </td>
                                    <td style="width:1px;">
                                        <ButtonDelete OnClick="() => DeleteAsync(item.SupplierId)" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </Body>
            </GenericList>
        </div>

        <hr class="border-top border-dark opacity-75 my-3" />

        <Pagination CurrentPage="CurrentPage"
                    SelectedPage="SelectedPage"
                    TotalPages="TotalPages" />
    </div>
</div>