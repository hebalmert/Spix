@page "/cargues"
@attribute [Authorize(Roles = "Administrator")]

<div class="container pt-4">
    <div class="card shadow-lg p-4 mb-5" style="border-radius: 12px;">
        <h3>Cargue de Seriales</h3>

        <div class="row align-items-center mb-3">
            <!-- Columna para el botón -->
            <div class="col-md-3 d-flex justify-content-start">
                <!-- Si decides reactivar el botón "Nuevo", usa tu componente personalizado -->
                @* <ButtonFormNew CssClass="btn btn-dark d-flex align-items-center gap-2" Style="width:130px" OnClick="ShowModalAsync" /> *@
            </div>

            <!-- Columna para el filtro -->
            <div class="col-md-9 d-flex justify-content-end">
                <FilterComponent ApplyFilter="SetFilterValue" />
            </div>
        </div>

        <hr class="my-4" />

        <div class="row">
            <div class="col-md-12 table-responsive">
                <GenericList MyList="Cargues">
                    <Body>
                        <table class="table table-hover table-striped align-middle">
                            <thead class="table-dark">
                                <tr>
                                    <th>Fecha</th>
                                    <th>Control</th>
                                    <th>Factura</th>
                                    <th>A Subir</th>
                                    <th>Subidos</th>
                                    <th>Estatus</th>
                                    <th></th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Cargues!)
                                {
                                    <tr>
                                        <td>@item.DateCargue</td>
                                        <td>@item.ControlCargue</td>
                                        <td>@item.PurchaseDetail!.Purchase!.NroFactura</td>
                                        <td>@item.CantToUp</td>
                                        <td>@item.TotalSeriales</td>
                                        <td>@item.Status.ToString()</td>
                                        <td style="width:1px;">
                                            <ButtonGeneric OnClick="() => ShowModalDetailsAsync(item.CargueId)" TooTip="@Localizer[nameof(Resource.Cargue)]"
                                                           Icon="fa fa-upload" />
                                        </td>
                                        <td style="width:1px;">
                                            @if (item.Status == CargueType.Pendiente)
                                            {
                                                <ButtonDelete OnClick="() => DeleteAsync(item.CargueId)" />
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </Body>
                </GenericList>
            </div>
        </div>

        <hr class="my-4" />

        <Pagination CurrentPage="CurrentPage"
                    SelectedPage="SelectedPage"
                    TotalPages="TotalPages" />
    </div>
</div>