<EditForm Model="CargueDetail" OnValidSubmit="OnSubmit">
    <DataAnnotationsValidator />

    <div class="mb-4">
        <label class="form-label">MAC Equipo</label>
        <InputText class="form-control" @bind-Value="CargueDetail.MacWlan" />
        <ValidationMessage For="@(() => CargueDetail.MacWlan)" />
    </div>

    <div class="mb-4">
        <label class="form-label">Comentario</label>
        <InputText class="form-control" @bind-Value="CargueDetail.Comment" />
        <ValidationMessage For="@(() => CargueDetail.Comment)" />
    </div>

    @if (ListUserType is null)
    {
        <Loading />
    }
    else
    {
        <div class="mb-4">
            <label class="form-label">--Seleccione Role--</label>
            <select class="form-select" value="@SelectedUserType!.Value" @onchange="UsertTypeChanged">
                @foreach (var item in ListUserType!)
                {
                    <option value="@item.Value">@item.Name</option>
                }
            </select>
        </div>
    }

    <!-- Botones -->
    <div class="d-flex justify-content-center gap-3 mt-5">
        <ButtonFormBack OnClick="ReturnAction" />
        <ButtonFormSave />
    </div>
</EditForm>
