@page "/transfers/create"
@attribute [Authorize(Roles = "Administrator")]

@if (Transfer is null)
{
    <Loading />
}
else
{
    ﻿<MudDialog>
        <DialogContent>
                <div class="container" style="width:300px">
                    <FormTransfer @ref=FormTransfer
                                 Transfer="Transfer"
                                 IsEditControl=false
                                 OnSubmit="Create"
                                 ReturnAction="Return"/>
                </div>
        </DialogContent>
    </MudDialog>
}

@if (Transfer is null)
{
    <FullScreenSpinner IsVisible="true" />
}
else
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); z-index: 1055;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content modal-create-shadow p-4 position-relative">
                <div class="modal-header d-flex justify-content-between align-items-center mb-3">
                    <h5 class="modal-title">
                        @Title
                    </h5>
                    <button class="btn-close-modal" @onclick="Return" title="Close">
                        <i class="fa fa-times"></i>
                    </button>
                </div>
                <FormTransfer @ref=FormTransfer
                              Transfer="Transfer"
                              IsEditControl=false
                              OnSubmit="Create"
                              ReturnAction="Return" />
            </div>
        </div>
    </div>
}