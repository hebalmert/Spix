<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand sidebar-brand" href="/dashboard">
            <img src="Images/LogoNexxtplanet.png" alt="NexxtPlanet" />
        </a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="nav flex-column">

        <!-- HOME -->
        <AuthorizeView Roles="Admin, Administrator, Auxiliar, Cachier, Collector, Contractor, WarehouseLead">
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/dashboard">
                        <span class="bi bi-house-door-fill-nav-menu"></span> Home
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView Roles="Client">
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/client-dashboard">
                        <span class="bi bi-house-door-fill-nav-menu"></span> Portal Cliente
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView Roles="Technician">
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/tech-dashboard">
                        <span class="bi bi-house-door-fill-nav-menu"></span> Portal Tecnico
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/schedule">
                        <span class="fa fa-calendar-days"></span> Schedule
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/servicerequests">
                        <span class="fa fa-clipboard-list"></span> Solicitud Servicio
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/cxcbills">
                        <span class="fa fa-cash-register"></span> Cuentas por Cobrar
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>

        <!-- PLATFORM SETUP -->
        <AuthorizeView Roles="Admin">
            <Authorized>
                <div class="nav-item px-3">
                    <button class="nav-link text-white d-flex align-items-center gap-2 w-100 nav-group"
                            @onclick="submenu1">
                        <span class="fa fa-th-large"></span>
                        @Localizer[nameof(Resource.PlatForm_Setup)]
                        <span class="ms-auto fa @(expandSubMenu1 ? "fa-chevron-up" : "fa-chevron-down")"></span>
                    </button>

                    @if (expandSubMenu1)
                    {
                        <NavLink class="nav-link text-white nav-subitem" href="/softplans">
                            <span class="fa fa-dot nav-subicon me-2"></span> Sofplans
                        </NavLink>
                        <NavLink class="nav-link text-white nav-subitem" href="/corporations">
                            <span class="fa fa-dot nav-subicon me-2"></span> Corporation
                        </NavLink>
                        <NavLink class="nav-link text-white nav-subitem" href="/managers">
                            <span class="fa fa-dot nav-subicon me-2"></span> Manager
                        </NavLink>
                    }
                </div>
            </Authorized>
        </AuthorizeView>

        <!-- OPERATIONAL SETUP -->
        <AuthorizeView Roles="Administrator">
            <Authorized>
                <div class="nav-item px-3">
                    <button class="nav-link text-white d-flex align-items-center gap-2 w-100 nav-group"
                            @onclick="submenu3">
                        <span class="fa fa-cogs"></span>
                        @Localizer[nameof(Resource.Menu_Setup)]
                        <span class="ms-auto fa @(expandSubMenu3 ? "fa-chevron-up" : "fa-chevron-down")"></span>
                    </button>

                    @if (expandSubMenu3)
                    {
                        <NavLink class="nav-link text-white nav-subitem" href="/zones">
                            <span class="fa fa-map-marker-alt nav-subicon me-2"></span> Zonas
                        </NavLink>
                        <NavLink class="nav-link text-white nav-subitem" href="/documenttypes">
                            <span class="fa fa-file nav-subicon me-2"></span> Tipo Documento
                        </NavLink>
                        <NavLink class="nav-link text-white nav-subitem" href="/taxes">
                            <span class="fa fa-percent nav-subicon me-2"></span> Impuestos
                        </NavLink>
                        <NavLink class="nav-link text-white nav-subitem" href="/registers">
                            <span class="fa fa-book nav-subicon me-2"></span> Registros
                        </NavLink>
                        <NavLink class="nav-link text-white nav-subitem" href="/contractdocumenttemplates">
                            <span class="fa fa-file-signature nav-subicon me-2"></span> Plantillas PDF
                        </NavLink>
                        <NavLink class="nav-link text-white nav-subitem" href="/emailproviders">
                            <span class="fa fa-envelope nav-subicon me-2"></span> Setup Emails
                        </NavLink>

                        <hr class="border-top border-light opacity-50 my-2" />

                        <NavLink class="nav-link text-white nav-subitem" href="/servicecategories">
                            <span class="fa fa-concierge-bell nav-subicon me-2"></span> Categoria/Servicios
                        </NavLink>
                        <NavLink class="nav-link text-white nav-subitem" href="/plancategories">
                            <span class="fa fa-sitemap nav-subicon me-2"></span> Categoria/Planes
                        </NavLink>
                    }
                </div>
            </Authorized>
        </AuthorizeView>

        <!-- PRODUCTS & STOCK -->
        <AuthorizeView Roles="Administrator">
            <Authorized>
                <div class="nav-item px-3">
                    <button class="nav-link text-white d-flex align-items-center gap-2 w-100 nav-group"
                            @onclick="submenu5">
                        <span class="fa fa-boxes"></span>
                        @Localizer[nameof(Resource.Menu_Inventory)]
                        <span class="ms-auto fa @(expandSubMenu5 ? "fa-chevron-up" : "fa-chevron-down")"></span>
                    </button>

                    @if (expandSubMenu5)
                    {
                        <NavLink class="nav-link text-white nav-subitem" href="/productcategories">
                            <span class="fa fa-boxes nav-subicon me-2"></span> Categoria/Productos
                        </NavLink>
                        <NavLink class="nav-link text-white nav-subitem" href="/marks/detailed">
                            <span class="fa fa-tags nav-subicon me-2"></span> Marca/Modelo
                        </NavLink>

                        <hr class="border-top border-light opacity-50 my-2" />

                        <NavLink class="nav-link text-white nav-subitem" href="/suppliers">
                            <span class="fa fa-truck nav-subicon me-2"></span> Proveedores
                        </NavLink>
                        <NavLink class="nav-link text-white nav-subitem" href="/productstorages">
                            <span class="fa fa-warehouse nav-subicon me-2"></span> Bodegas
                        </NavLink>

                        <hr class="border-top border-light opacity-50 my-2" />

                        <NavLink class="nav-link text-white nav-subitem" href="/purchases">
                            <span class="fa fa-shopping-cart nav-subicon me-2"></span> Compras
                        </NavLink>
                        <NavLink class="nav-link text-white nav-subitem" href="/cargues">
                            <span class="fa fa-barcode nav-subicon me-2"></span> Cargue Serials
                        </NavLink>
                    }
                </div>
            </Authorized>
        </AuthorizeView>

        <!-- NETWORK MANAGEMENT -->
        <AuthorizeView Roles="Administrator">
            <Authorized>
                <div class="nav-item px-3">
                    <button class="nav-link text-white d-flex align-items-center gap-2 w-100 nav-group"
                            @onclick="submenu4">
                        <span class="fa fa-network-wired"></span>
                        @Localizer[nameof(Resource.Menu_Network)]
                        <span class="ms-auto fa @(expandSubMenu4 ? "fa-chevron-up" : "fa-chevron-down")"></span>
                    </button>

                    @if (expandSubMenu4)
                    {
                        <NavLink class="nav-link text-white nav-subitem" href="/ipnets">
                            <span class="fa fa-laptop nav-subicon me-2"></span> Ip Clientes
                        </NavLink>
                        <NavLink class="nav-link text-white nav-subitem" href="/ipnetworks">
                            <span class="fa fa-project-diagram nav-subicon me-2"></span> Ip Red
                        </NavLink>

                        <hr class="border-top border-light opacity-50 my-2" />

                        <NavLink class="nav-link text-white nav-subitem" href="/connectionmikrotikcontrols">
                            <span class="fa fa-network-wired nav-subicon me-2"></span> Control Mikrotik
                        </NavLink>
                        <NavLink class="nav-link text-white nav-subitem" href="/queuetypes">
                            <span class="fa fa-sliders-h nav-subicon me-2"></span> Queue Types
                        </NavLink>

                        <hr class="border-top border-light opacity-50 my-2" />

                        <NavLink class="nav-link text-white nav-subitem" href="/nodes">
                            <span class="fa fa-server nav-subicon me-2"></span> Nodos
                        </NavLink>
                        <NavLink class="nav-link text-white nav-subitem" href="/servers">
                            <span class="fa fa-database nav-subicon me-2"></span> Servidores
                        </NavLink>
                    }
                </div>
            </Authorized>
        </AuthorizeView>

        <!-- OPERATIONS -->
        <AuthorizeView Roles="Administrator">
            <Authorized>
                <div class="nav-item px-3">
                    <button class="nav-link text-white d-flex align-items-center gap-2 w-100 nav-group"
                            @onclick="submenu6">
                        <span class="fa fa-briefcase"></span>
                        @Localizer[nameof(Resource.Menu_Operation)]
                        <span class="ms-auto fa @(expandSubMenu6 ? "fa-chevron-up" : "fa-chevron-down")"></span>
                    </button>

                    @if (expandSubMenu6)
                    {
                        <NavLink class="nav-link text-white nav-subitem" href="/schedule">
                            <span class="fa fa-users nav-subicon me-2"></span> Schedule
                        </NavLink>
                        <hr class="border-top border-light opacity-50 my-2" />
                        <NavLink class="nav-link text-white nav-subitem" href="/clients">
                            <span class="fa fa-users nav-subicon me-2"></span> Clientes
                        </NavLink>
                        <NavLink class="nav-link text-white nav-subitem" href="/contractclients">
                            <span class="fa fa-users nav-subicon me-2"></span> Contract Clients
                        </NavLink>
                        <hr class="border-top border-light opacity-50 my-2" />
                        <NavLink class="nav-link text-white nav-subitem" href="/contractcontrol">
                            <span class="fa fa-users nav-subicon me-2"></span> Contract Control
                        </NavLink>
                        <NavLink class="nav-link text-white nav-subitem" href="/servicerequests">
                            <span class="fa fa-tools nav-subicon me-2"></span> Solicitud Servicio
                        </NavLink>
                    }
                </div>
            </Authorized>
        </AuthorizeView>

        <!-- BILLING & PAYMENTS -->
        <AuthorizeView Roles="Administrator">
            <Authorized>
                <div class="nav-item px-3">
                    <button class="nav-link text-white d-flex align-items-center gap-2 w-100 nav-group"
                            @onclick="submenu7">
                        <span class="fa fa-file-invoice-dollar"></span>
                        Finanzas
                        <span class="ms-auto fa @(expandSubMenu7 ? "fa-chevron-up" : "fa-chevron-down")"></span>
                    </button>

                    @if (expandSubMenu7)
                    {
                        <NavLink class="nav-link text-white nav-subitem" href="/billingnotes">
                            <span class="fa fa-calendar-alt nav-subicon me-2"></span> Billing Notes
                        </NavLink>
                        <NavLink class="nav-link text-white nav-subitem" href="/billingnoteones">
                            <span class="fa fa-user-clock nav-subicon me-2"></span> Billing Note One
                        </NavLink>

                        <hr class="border-top border-light opacity-50 my-2" />

                        <NavLink class="nav-link text-white nav-subitem" href="/sells">
                            <span class="fa fa-file-invoice nav-subicon me-2"></span> Facturas
                        </NavLink>
                        <NavLink class="nav-link text-white nav-subitem" href="/cxcbills">
                            <span class="fa fa-cash-register nav-subicon me-2"></span> Cuentas por Cobrar
                        </NavLink>
                        <NavLink class="nav-link text-white nav-subitem" href="/prepayments">
                            <span class="fa fa-hand-holding-dollar nav-subicon me-2"></span> Pagos Adelantados
                        </NavLink>
                        <NavLink class="nav-link text-white nav-subitem" href="/preexonerateds">
                            <span class="fa fa-percent nav-subicon me-2"></span> Exoneraciones
                        </NavLink>
                    }
                </div>
            </Authorized>
        </AuthorizeView>

        <!-- SYSTEM SETTINGS -->
        <AuthorizeView Roles="Administrator">
            <Authorized>
                <div class="nav-item px-3">
                    <button class="nav-link text-white d-flex align-items-center gap-2 w-100 nav-group"
                            @onclick="submenu2">
                        <span class="fa fa-gears"></span>
                        System Setting
                        <span class="ms-auto fa @(expandSubMenu2 ? "fa-chevron-up" : "fa-chevron-down")"></span>
                    </button>

                    @if (expandSubMenu2)
                    {
                        <NavLink class="nav-link text-white nav-subitem" href="/usuarios">
                            <span class="fa fa-user nav-subicon me-2"></span> User
                        </NavLink>

                        <hr class="border-top border-light opacity-50 my-2" />

                        <NavLink class="nav-link text-white nav-subitem" href="/contractors">
                            <span class="fa fa-user-tie nav-subicon me-2"></span> Contratistas
                        </NavLink>
                        <NavLink class="nav-link text-white nav-subitem" href="/technitians">
                            <span class="fa fa-user-tie nav-subicon me-2"></span> Tecnicos
                        </NavLink>
                    }
                </div>
            </Authorized>
        </AuthorizeView>

    </nav>
</div>


@code {

    [Inject] private IStringLocalizer<Resource> Localizer { get; set; } = null!;

    private bool collapseNavMenu = true;

    private bool expandSubMenu1;
    private bool expandSubMenu2;
    private bool expandSubMenu3;
    private bool expandSubMenu4;
    private bool expandSubMenu5;
    private bool expandSubMenu6;
    private bool expandSubMenu7;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
    private void submenu1()
    {
        expandSubMenu1 = !expandSubMenu1;
        expandSubMenu2 = false;
        expandSubMenu3 = false;
        expandSubMenu4 = false;
        expandSubMenu5 = false;
        expandSubMenu6 = false;
        expandSubMenu7 = false;
    }

    private void submenu2()
    {
        expandSubMenu2 = !expandSubMenu2;
        expandSubMenu1 = false;
        expandSubMenu3 = false;
        expandSubMenu4 = false;
        expandSubMenu5 = false;
        expandSubMenu6 = false;
        expandSubMenu7 = false;
    }
    private void submenu3()
    {
        expandSubMenu3 = !expandSubMenu3;
        expandSubMenu1 = false;
        expandSubMenu2 = false;
        expandSubMenu4 = false;
        expandSubMenu5 = false;
        expandSubMenu6 = false;
        expandSubMenu7 = false;
    }
    private void submenu4()
    {
        expandSubMenu4 = !expandSubMenu4;
        expandSubMenu1 = false;
        expandSubMenu2 = false;
        expandSubMenu3 = false;
        expandSubMenu5 = false;
        expandSubMenu6 = false;
        expandSubMenu7 = false;
    }
    private void submenu5()
    {
        expandSubMenu5 = !expandSubMenu5;
        expandSubMenu1 = false;
        expandSubMenu2 = false;
        expandSubMenu3 = false;
        expandSubMenu4 = false;
        expandSubMenu6 = false;
        expandSubMenu7 = false;
    }
    private void submenu6()
    {
        expandSubMenu6 = !expandSubMenu6;
        expandSubMenu1 = false;
        expandSubMenu2 = false;
        expandSubMenu3 = false;
        expandSubMenu4 = false;
        expandSubMenu5 = false;
        expandSubMenu7 = false;
    }
    private void submenu7()
    {
        expandSubMenu7 = !expandSubMenu7;
        expandSubMenu1 = false;
        expandSubMenu2 = false;
        expandSubMenu3 = false;
        expandSubMenu4 = false;
        expandSubMenu5 = false;
        expandSubMenu6 = false;
    }
}
